<!doctype html>
<html :lang="app.lang" prefix="og: http://ogp.me/ns#">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title webc:is="page-title" webc:nokeep></title>

  <script nonce="bVgyaDV6YU9tdThnZ2wwckZBNnFnc1Z6Wk40SnY2U0pmbjdTUjQ3MVg2RTFCbnEwN3g=">
    if (navigator.serviceWorker) {
      navigator.serviceWorker.register('/serviceworker.js');
      if (navigator.serviceWorker.controller) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.controller.postMessage({
            command: 'trimCaches'
          });
        });
      }
    }
  </script>

  <link rel="preconnect" href="https://kit.paulrobertlloyd.com">
  <link rel="dns-prefetch" href="https://kit.paulrobertlloyd.com">
  <link rel="alternate" href="/feed.xml" type="application/atom+xml" title="RSS (Atom) Feed">
  <link rel="alternate" href="/feed.json" type="application/feed+json" title="JSON Feed">
  <link rel="canonical" :href="canonical_url">
  <link rel="manifest" href="/app.webmanifest">
  <link rel="icon" :href="app.favicon">
  <link rel="apple-touch-icon" :href="app.icon">
  <link rel="authorization_endpoint" :href="app.endpoint.auth">
  <link rel="token_endpoint" :href="app.endpoint.token">
  <link rel="indieauth-metadata" :href="app.endpoint.indieauth">
  <link rel="micropub" :href="app.endpoint.micropub">
  <link rel="microsub" :href="app.endpoint.microsub">
  <link rel="webmention" :href="app.endpoint.webmention">
  <link rel="pgpkey" href="/app.pgp">
  <link rel="stylesheet" href="/app.css" webc:raw>

  <meta property="og:title" :content="title">
  <meta property="og:description" name="description" :content="summary">
  <meta property="og:url" :content="absolute_url(page.url, app.url)">
  <meta property="og:image" :content="absolute_url(summary_image, app.url)">
  <meta property="og:image:alt" :content="summary_image_alt">
  <meta name="theme-color" :content="app.theme_color" media="(prefers-color-scheme: light)">
  <meta name="theme-color" :content="app.theme_color_dark" media="(prefers-color-scheme: dark)">
  <meta name="supported-color-schemes" content="light dark">
  <meta name="robots" content="index, follow">
</head>

<body :data-type="layout" :id="id">
  <skip-link></skip-link>
  <banner></banner>
  <main>
    <template @html="content" webc:nokeep></template>
  </main>
  <contentinfo></contentinfo>
</body>
</html>
