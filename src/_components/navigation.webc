<ul class="navigation" role="list">
  <li webc:for="item of items">
    <a :rel="item.rel" :href="item.url" :aria-current="layout === item.post_type || page.url.includes(item.url)">
      <icon webc:if="item.icon" :@id="item.icon" :@label="item.label" @size="20"></icon>
      <span webc:else @text="item.label"></span>
    </a>
  </li>
</ul>
